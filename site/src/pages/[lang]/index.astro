---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { copy, isLang } from '../../lib/i18n';
import { getProducts } from '../../lib/sanity';
export const prerender = false;
const langParam = Astro.params.lang || 'en';
if (!isLang(langParam)) return Astro.redirect('/en/');
const lang = langParam;
const t = copy[lang];
const products = await getProducts();
---
<Base lang={lang}>
<main>
<section class="container hero"><div><div class="eyebrow">{t.heroEyebrow}</div><h1>{t.heroTitle}</h1><p>{t.heroText}</p><div class="actions"><a class="btn primary" href="#collection">{t.explore}</a><a class="btn" href="#custom">{t.request}</a></div></div><div class="hero-media"><img src="/images/products/wall-art-main.png" alt="IZEN handmade epoxy resin art"></div></section>
<section class="section white" id="about"><div class="container"><h2>{t.promiseTitle}</h2><p class="lead">{t.promiseText}</p></div></section>
<section class="section" id="collection"><div class="container"><h2>{t.collectionTitle}</h2><p class="lead">{t.collectionText}</p><div class="grid">{products.map((product:any)=><ProductCard product={product} lang={lang} t={t}/>)}</div></div></section>
<section class="section white"><div class="container gift"><img src="/images/products/phone-stand-black-main.png" alt="Unique handmade gift"><div><div class="eyebrow">IZEN</div><h2>{t.giftTitle}</h2><p class="lead">{t.giftText}</p></div></div></section>
<section class="section dark" id="custom"><div class="container"><h2>{t.customTitle}</h2><p class="lead">{t.customText}</p><div class="steps">{t.process.map((item,i)=><div class="step"><b>0{i+1}</b><p>{item}</p></div>)}</div></div></section>
<section class="section white" id="contact"><div class="container"><h2>{t.contactTitle}</h2><form class="form" action="https://formsubmit.co/izenfze@gmail.com" method="POST"><input name="name" placeholder={t.orderForm.name} required><input name="phone" placeholder={t.orderForm.phone} required><input type="email" name="email" placeholder={t.orderForm.email}><input name="city" placeholder={t.orderForm.city}><textarea name="idea" placeholder={t.orderForm.idea} required></textarea><input type="hidden" name="_subject" value="New IZEN custom order request"><button class="btn primary" type="submit">{t.orderForm.submit}</button></form><div class="actions"><a class="btn" href="https://wa.me/971525988304">{t.whatsapp}</a><a class="btn" href="mailto:izenfze@gmail.com">{t.email}</a></div></div></section>
</main>
</Base>
